---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { callStats, months } from '../../data/department';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const typeLabel: Record<string, string> = {
  ems: t('dashboard.ems'),
  fire: t('dashboard.fire'),
  rescue: t('dashboard.rescue'),
  service: t('dashboard.service'),
  hazmat: t('dashboard.hazmat'),
};

const total = callStats.byType.reduce((a, b) => a + b.value, 0);

// donut geometry
const radius = 80;
const circumference = 2 * Math.PI * radius;
let offset = 0;
const segments = callStats.byType.map((s) => {
  const fraction = s.value / total;
  const dash = fraction * circumference;
  const seg = { ...s, dash, gap: circumference - dash, rotation: (offset / total) * 360 };
  offset += s.value;
  return seg;
});

const maxMonth = Math.max(...callStats.monthly);
const monthLabels = months[lang];
---

<section class="bg-ink-50 py-20">
  <div class="container-page">
    <div class="reveal max-w-2xl">
      <p class="kicker">{t('dashboard.title')}</p>
      <h2 class="mt-3 text-3xl uppercase sm:text-4xl">{t('dashboard.title')}</h2>
      <p class="mt-3 text-ink-600">{t('dashboard.subtitle')}</p>
    </div>

    <div class="mt-12 grid gap-8 lg:grid-cols-[0.85fr_1.15fr]">
      <!-- Donut by type -->
      <div class="reveal rounded-xl border border-ink-200 bg-white p-6 shadow-sm">
        <div class="flex flex-col items-center gap-6 sm:flex-row">
          <div class="relative shrink-0">
            <svg viewBox="0 0 200 200" class="h-48 w-48 -rotate-90">
              {
                segments.map((s) => (
                  <circle
                    cx="100"
                    cy="100"
                    r={radius}
                    fill="none"
                    stroke={s.color}
                    stroke-width="26"
                    stroke-dasharray={`${s.dash} ${s.gap}`}
                    stroke-dashoffset={-(s.rotation / 360) * circumference}
                  />
                ))
              }
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span class="heading-condensed text-3xl font-bold text-ink-900">{callStats.total.toLocaleString(lang)}</span>
              <span class="text-xs uppercase tracking-wider text-ink-500">{t('dashboard.total')}</span>
            </div>
          </div>
          <ul class="w-full space-y-2.5">
            {
              segments.map((s) => (
                <li class="flex items-center justify-between gap-3 text-sm">
                  <span class="flex items-center gap-2">
                    <span class="h-3 w-3 rounded-sm" style={`background:${s.color}`}></span>
                    <span class="text-ink-700">{typeLabel[s.key]}</span>
                  </span>
                  <span class="font-semibold text-ink-900">{s.value.toLocaleString(lang)}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- Monthly bars -->
      <div class="reveal rounded-xl border border-ink-200 bg-white p-6 shadow-sm">
        <h3 class="heading-condensed text-sm uppercase tracking-wider text-ink-500">{t('dashboard.monthly')}</h3>
        <div class="mt-6 flex h-56 items-end justify-between gap-1.5 sm:gap-2.5">
          {
            callStats.monthly.map((v, i) => (
              <div class="group flex h-full flex-1 flex-col items-center justify-end gap-2">
                <span class="text-[10px] font-semibold text-ink-400 opacity-0 transition-opacity group-hover:opacity-100">{v}</span>
                <div
                  class="w-full rounded-t bg-fire-600 transition-colors group-hover:bg-fire-500"
                  style={`height:${Math.round((v / maxMonth) * 100)}%`}
                ></div>
                <span class="text-[10px] text-ink-500">{monthLabels[i]}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
