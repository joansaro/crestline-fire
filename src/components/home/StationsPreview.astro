---
import { getLangFromUrl, useTranslations, localizePath } from '../../i18n/utils';
import { stations } from '../../data/department';
import StationCard from '../StationCard.astro';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="bg-white py-20">
  <div class="container-page">
    <div class="reveal flex flex-wrap items-end justify-between gap-4">
      <div class="max-w-2xl">
        <p class="kicker">{t('stations.kicker')}</p>
        <h2 class="mt-3 text-3xl uppercase sm:text-4xl">{t('stations.title')}</h2>
        <p class="mt-3 text-ink-600">{t('stations.subtitle')}</p>
      </div>
      <a href={localizePath('/stations', lang)} class="inline-flex items-center gap-2 font-semibold text-fire-600 hover:text-fire-700">
        {t('stations.viewAll')}
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {stations.map((s) => <StationCard station={s} />)}
    </div>
  </div>
</section>
