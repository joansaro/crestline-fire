---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const stats = [
  { value: 'stats.calls.value', label: 'stats.calls.label' },
  { value: 'stats.firefighters.value', label: 'stats.firefighters.label' },
  { value: 'stats.area.value', label: 'stats.area.label' },
  { value: 'stats.residents.value', label: 'stats.residents.label' },
] as const;
---

<section class="relative z-10 -mt-px bg-fire-700 text-white">
  <div class="container-page grid grid-cols-2 divide-x divide-fire-600/60 lg:grid-cols-4">
    {
      stats.map((s) => (
        <div class="reveal px-4 py-8 text-center sm:py-10">
          <div class="heading-condensed text-4xl font-bold sm:text-5xl">{t(s.value)}</div>
          <div class="mt-2 text-xs uppercase tracking-wider text-fire-100 sm:text-sm">{t(s.label)}</div>
        </div>
      ))
    }
  </div>
</section>
