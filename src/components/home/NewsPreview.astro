---
import { getLangFromUrl, useTranslations, localizePath } from '../../i18n/utils';
import { news } from '../../data/department';
import NewsCard from '../NewsCard.astro';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const latest = news.slice(0, 3);
---

<section class="bg-ink-50 py-20">
  <div class="container-page">
    <div class="reveal flex flex-wrap items-end justify-between gap-4">
      <div class="max-w-2xl">
        <p class="kicker">{t('news.kicker')}</p>
        <h2 class="mt-3 text-3xl uppercase sm:text-4xl">{t('news.title')}</h2>
        <p class="mt-3 text-ink-600">{t('news.subtitle')}</p>
      </div>
      <a href={localizePath('/news', lang)} class="inline-flex items-center gap-2 font-semibold text-fire-600 hover:text-fire-700">
        {t('news.viewAll')}
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {latest.map((item) => <NewsCard item={item} />)}
    </div>
  </div>
</section>
