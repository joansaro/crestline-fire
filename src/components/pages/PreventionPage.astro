---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../PageHeader.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const tips = [
  { title: 'prevention.tip1.title', text: 'prevention.tip1.text' },
  { title: 'prevention.tip2.title', text: 'prevention.tip2.text' },
  { title: 'prevention.tip3.title', text: 'prevention.tip3.text' },
  { title: 'prevention.tip4.title', text: 'prevention.tip4.text' },
  { title: 'prevention.tip5.title', text: 'prevention.tip5.text' },
  { title: 'prevention.tip6.title', text: 'prevention.tip6.text' },
] as const;

const programs = [
  'prevention.program1', 'prevention.program2',
  'prevention.program3', 'prevention.program4',
] as const;
---

<BaseLayout title={t('prevention.title')}>
  <PageHeader
    kicker={t('brand.short')}
    title={t('prevention.title')}
    subtitle={t('prevention.subtitle')}
    image="https://upload.wikimedia.org/wikipedia/commons/thumb/7/70/080723-N-0780F-005.jpg/1920px-080723-N-0780F-005.jpg"
  />

  <!-- Tips -->
  <section class="bg-white py-20">
    <div class="container-page">
      <h2 class="reveal text-3xl uppercase sm:text-4xl">{t('prevention.tips.title')}</h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          tips.map((tip, i) => (
            <article class="reveal rounded-xl border border-ink-200 bg-ink-50 p-6">
              <span class="heading-condensed inline-flex h-10 w-10 items-center justify-center rounded-lg bg-fire-600 text-lg font-bold text-white">
                {i + 1}
              </span>
              <h3 class="mt-4 heading-condensed text-lg uppercase text-ink-900">{t(tip.title)}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-600">{t(tip.text)}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Programs -->
  <section class="bg-ink-950 py-20 text-white">
    <div class="container-page">
      <h2 class="reveal text-3xl uppercase sm:text-4xl">{t('prevention.programs.title')}</h2>
      <ul class="mt-8 grid gap-4 sm:grid-cols-2">
        {
          programs.map((p) => (
            <li class="reveal flex items-center gap-4 rounded-lg border border-white/10 bg-white/5 p-5">
              <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-fire-600">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </span>
              <span class="text-ink-100">{t(p)}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
