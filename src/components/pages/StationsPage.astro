---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../PageHeader.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { stations } from '../../data/department';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={t('stations.page.title')}>
  <PageHeader
    kicker={t('brand.short')}
    title={t('stations.page.title')}
    subtitle={t('stations.page.subtitle')}
    image="https://upload.wikimedia.org/wikipedia/commons/thumb/3/33/Willits_Fire_Station_54_-_February_2023_-_Sarah_Stierch_03.jpg/1920px-Willits_Fire_Station_54_-_February_2023_-_Sarah_Stierch_03.jpg"
  />

  <section class="bg-ink-50 py-20">
    <div class="container-page space-y-8">
      {
        stations.map((s, i) => (
          <article class="reveal grid overflow-hidden rounded-xl border border-ink-200 bg-white shadow-sm lg:grid-cols-2">
            <div class:list={['aspect-[16/10] overflow-hidden lg:aspect-auto', i % 2 === 1 && 'lg:order-2']}>
              <img src={s.image} alt={s.name[lang]} class="h-full w-full object-cover" loading="lazy" />
            </div>
            <div class="p-8">
              <span class="rounded-md bg-fire-700 px-2.5 py-1 text-xs font-bold uppercase tracking-wider text-white">
                #{s.number}
              </span>
              <h2 class="mt-3 heading-condensed text-2xl uppercase text-ink-900">{s.name[lang]}</h2>
              <dl class="mt-5 space-y-3 text-sm">
                <div class="flex gap-3">
                  <dt class="w-28 shrink-0 font-semibold uppercase tracking-wide text-ink-400">{t('stations.address')}</dt>
                  <dd class="text-ink-700">{s.address}</dd>
                </div>
                <div class="flex gap-3">
                  <dt class="w-28 shrink-0 font-semibold uppercase tracking-wide text-ink-400">{t('stations.phone')}</dt>
                  <dd class="text-ink-700">{s.phone}</dd>
                </div>
                <div class="flex gap-3">
                  <dt class="w-28 shrink-0 font-semibold uppercase tracking-wide text-ink-400">{t('stations.crewSize')}</dt>
                  <dd class="text-ink-700">{s.crew}</dd>
                </div>
                <div class="flex gap-3">
                  <dt class="w-28 shrink-0 font-semibold uppercase tracking-wide text-ink-400">{t('stations.apparatus')}</dt>
                  <dd class="text-ink-700">{s.apparatus}</dd>
                </div>
                <div class="flex gap-3">
                  <dt class="w-28 shrink-0 font-semibold uppercase tracking-wide text-ink-400">{t('stations.builtIn')}</dt>
                  <dd class="text-ink-700">{s.built}</dd>
                </div>
              </dl>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
