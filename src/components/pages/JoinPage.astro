---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../PageHeader.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const roles = [
  { title: 'join.role.ff', desc: 'join.role.ff.desc' },
  { title: 'join.role.emt', desc: 'join.role.emt.desc' },
  { title: 'join.role.volunteer', desc: 'join.role.volunteer.desc' },
  { title: 'join.role.cadet', desc: 'join.role.cadet.desc' },
] as const;
---

<BaseLayout title={t('join.page.title')}>
  <PageHeader
    kicker={t('join.kicker')}
    title={t('join.page.title')}
    subtitle={t('join.page.intro')}
    image="https://upload.wikimedia.org/wikipedia/commons/thumb/1/11/Defense.gov_News_Photo_120723-F-HA794-089_-_A_U.S._Air_Force_firefighter_sprays_water_at_the_fire_of_a_simulated_C-130_Hercules_plane_crash_during_operational_readiness_exercise_Beverly.jpg/1920px-thumbnail.jpg"
  />

  <!-- Roles -->
  <section class="bg-white py-20">
    <div class="container-page">
      <h2 class="reveal text-3xl uppercase sm:text-4xl">{t('join.roles.title')}</h2>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {
          roles.map((r, i) => (
            <article class="reveal flex gap-5 rounded-xl border border-ink-200 bg-ink-50 p-6">
              <span class="heading-condensed text-4xl font-bold text-fire-600">0{i + 1}</span>
              <div>
                <h3 class="heading-condensed text-xl uppercase text-ink-900">{t(r.title)}</h3>
                <p class="mt-2 text-sm leading-relaxed text-ink-600">{t(r.desc)}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Requirements + Form -->
  <section class="bg-ink-50 py-20">
    <div class="container-page grid gap-10 lg:grid-cols-2">
      <div class="reveal">
        <h2 class="text-3xl uppercase sm:text-4xl">{t('join.req.title')}</h2>
        <ul class="mt-6 space-y-4">
          {
            (['join.req1', 'join.req2', 'join.req3', 'join.req4'] as const).map((r) => (
              <li class="flex items-start gap-3 rounded-lg border border-ink-200 bg-white p-4">
                <span class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-fire-600">
                  <svg class="h-3.5 w-3.5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                </span>
                <span class="text-ink-700">{t(r)}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="reveal rounded-xl border border-ink-200 bg-white p-7 shadow-sm">
        <h2 class="heading-condensed text-2xl uppercase text-ink-900">{t('join.form.title')}</h2>
        <form class="mt-6 space-y-4" onsubmit="event.preventDefault(); this.reset(); document.getElementById('join-ok').classList.remove('hidden');">
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block">
              <span class="mb-1 block text-sm font-medium text-ink-700">{t('join.form.name')}</span>
              <input type="text" required class="w-full rounded-md border border-ink-300 px-3 py-2.5 outline-none focus:border-fire-600" />
            </label>
            <label class="block">
              <span class="mb-1 block text-sm font-medium text-ink-700">{t('join.form.phone')}</span>
              <input type="tel" class="w-full rounded-md border border-ink-300 px-3 py-2.5 outline-none focus:border-fire-600" />
            </label>
          </div>
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-ink-700">{t('join.form.email')}</span>
            <input type="email" required class="w-full rounded-md border border-ink-300 px-3 py-2.5 outline-none focus:border-fire-600" />
          </label>
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-ink-700">{t('join.form.position')}</span>
            <select class="w-full rounded-md border border-ink-300 px-3 py-2.5 outline-none focus:border-fire-600">
              {roles.map((r) => <option>{t(r.title)}</option>)}
            </select>
          </label>
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-ink-700">{t('join.form.message')}</span>
            <textarea rows="4" class="w-full rounded-md border border-ink-300 px-3 py-2.5 outline-none focus:border-fire-600"></textarea>
          </label>
          <button type="submit" class="w-full rounded-md bg-fire-600 px-6 py-3 font-semibold text-white transition-colors hover:bg-fire-500">
            {t('join.form.submit')}
          </button>
          <p id="join-ok" class="hidden rounded-md bg-green-50 px-4 py-3 text-sm text-green-700">✓ {t('join.form.note')}</p>
          <p class="text-center text-xs text-ink-400">{t('join.form.note')}</p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
